# Google Places API (New) — server only
# https://console.cloud.google.com → APIs & Services → Places API (New) 활성화
# API Key 생성 후 "Application restrictions"는 "None"(서버 사용),
# "API restrictions"는 "Places API (New)"만 허용 권장
GOOGLE_PLACES_API_KEY=

# Vercel AI Gateway — server only
# https://vercel.com/dashboard/ai-gateway 에서 발급
AI_GATEWAY_API_KEY=

# 앱 공개 URL (manifest start_url + canonical 용)
NEXT_PUBLIC_APP_URL=http://localhost:3000
